                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.EntityFrameworkCore": "Warning"
            }
        },
        "ApplicationInsights": {
            "LogLevel": {
                "Default": "Warning"
            }
        },
        "LoggerAdapter": {
            "LogLevel": {
                "Default": "Information",
